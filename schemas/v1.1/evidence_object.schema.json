{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/v0-osap/v1.1/evidence_object.schema.json",
  "title": "Evidence Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "evidence_type",
    "evidence_level",
    "produced_by",
    "supports_claim_ids",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "v1.1"
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
    },
    "evidence_type": {
      "type": "string",
      "minLength": 1
    },
    "evidence_level": {
      "enum": [
        "E0_SPECIFIED",
        "E1_SCHEMA_VALID",
        "E2_CHECKER_REPLAYED",
        "E3_MODEL_WITNESSED",
        "E4_PROOF_ASSISTANT_COMPILED",
        "E5_CROSS_ASSISTANT_REPLAYED"
      ]
    },
    "source_uri": {
      "type": "string"
    },
    "source_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "produced_by": {
      "type": "string",
      "minLength": 1
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    },
    "registry_state_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
    },
    "supports_claim_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
      },
      "uniqueItems": true
    },
    "independence_group_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
