          "distinctness_basis": {
            "enum": [
              "label_only",
              "non_isomorphism",
              "incompatible_profile",
              "observational_separation",
              "registered_policy"
            ]
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "branch_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "cardinality_kind": {
            "enum": [
