          },
          "first_replay_result": {},
          "second_replay_result": {},
          "from_schema_version": {
            "type": "string"
          },
          "to_schema_version": {
            "type": "string"
          },
          "from_semantic_version": {
            "type": "string"
          },
          "to_semantic_version": {
            "type": "string"
          },
          "parser_coercion": {
