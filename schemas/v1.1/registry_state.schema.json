            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "theorem_id": {
            "type": "string",
            "pattern": "^T[0-9]+$"
          },
          "canonical_statement_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "lean_statement_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "coq_statement_hash": {
            "type": "string",
