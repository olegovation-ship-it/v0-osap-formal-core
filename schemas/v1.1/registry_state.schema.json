          "non_circular": {
            "type": "boolean"
          },
          "identity_verified": {
            "type": "boolean"
          },
          "evidence_verified": {
            "type": "boolean"
          },
          "container_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "contained_branch_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "containment_mode": {
            "enum": [
              "none",
              "ordinary",
              "typed_meta"
