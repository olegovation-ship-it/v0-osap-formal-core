{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/v0-osap/v1.1/registry_state.schema.json",
  "title": "Registry State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "language_version",
    "registry_state_id",
    "declarations",
    "contexts",
    "tokens",
    "prerequisite_families",
    "compatibility_constraints",
    "protocols",
    "residual_links",
    "observers",
    "branches",
    "evidence_objects",
    "claims",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "v1.1"
    },
    "language_version": {
      "const": "FC-1-v1.1"
    },
    "registry_state_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
    },
    "predecessor_state_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
    },
    "declarations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "sort"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "sort": {
            "enum": [
              "Sector",
              "NullMark",
              "Register",
              "Context",
              "RegistryState",
              "Token",
              "Protocol",
              "Observer",
              "Branch",
              "Evidence",
              "Claim",
              "ProofObject",
              "Diagnostic"
            ]
          },
          "label": {
            "type": "string"
          }
        }
      }
    },
    "contexts": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
      },
      "uniqueItems": true
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "token_id",
          "carrier_id",
          "register_id",
          "context_id",
          "partition",
          "introduced_in",
          "source_evidence_id"
        ],
        "properties": {
          "token_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "carrier_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "register_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "context_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "partition": {
            "enum": [
              "live",
              "historical",
              "retired",
              "deferred"
            ]
          },
          "introduced_in": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "moved_in": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "source_evidence_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          }
        }
      }
    },
    "prerequisite_families": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "family_id",
          "target_register_id",
          "mode",
          "prerequisite_register_ids",
          "context_policy",
          "evidence_ids",
          "enabled"
        ],
        "properties": {
          "family_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "target_register_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "mode": {
            "enum": [
              "all_of",
              "one_of"
            ]
          },
          "prerequisite_register_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "context_policy": {
            "type": "string"
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "enabled": {
            "type": "boolean"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "mode": {
                  "const": "one_of"
                }
              },
              "required": [
                "mode"
              ]
            },
            "then": {
              "properties": {
                "prerequisite_register_ids": {
                  "minItems": 1
                }
              }
            }
          }
        ]
      }
    },
    "compatibility_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "constraint_id",
          "left_register_id",
          "right_register_id",
          "relation",
          "enabled"
        ],
        "properties": {
          "constraint_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "left_register_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "right_register_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "relation": {
            "const": "incompatible"
          },
          "context_policy": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    },
    "protocols": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "protocol_id",
          "prerequisite_register_ids",
          "enabled"
        ],
        "properties": {
          "protocol_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "prerequisite_register_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "enabled": {
            "type": "boolean"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    },
    "residual_links": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "observers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "branches": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "evidence_objects": {
      "type": "array",
      "items": {
        "$ref": "evidence_object.schema.json"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "kind": {
            "type": "string"
          },
          "carrier_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "register_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "context_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "source_claim_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "family_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "selected_register_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "seed_register_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "computed_closure_register_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "active_register_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "protocol_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "readiness_status": {
            "enum": [
              "READY_VALUE",
              "UNDEFINED_DOMAIN",
              "NOT_READY"
            ]
          },
          "dimension_status": {
            "enum": [
              "READY_VALUE",
              "UNDEFINED_DOMAIN"
            ]
          },
          "numeric_value": {
            "type": "number"
          },
          "residual_register_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "internal_support_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "external_evidence_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "independence_group_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "prior_token_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "reactivated_token_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "non_eliminable_residual_register_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
            },
            "uniqueItems": true
          },
          "support_state_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          },
          "certification_state_id": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "prerequisite_closure"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "seed_register_ids",
                "computed_closure_register_ids"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "one_of_support_selection"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "family_id",
                "selected_register_id",
                "carrier_id",
                "context_id"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "activation_profile"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "carrier_id",
                "context_id",
                "active_register_ids"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "protocol_readiness"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "protocol_id",
                "carrier_id",
                "context_id",
                "readiness_status"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "dimension_result"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "protocol_id",
                "dimension_status"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "reactivation"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "prior_token_id",
                "reactivated_token_id"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "raw_relative_v0"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "carrier_id",
                "register_id",
                "context_id",
                "residual_register_ids"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "robust_relative_v0_noneliminable"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "carrier_id",
                "register_id",
                "context_id",
                "non_eliminable_residual_register_ids"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "v0_identity"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "source_claim_id"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "terminal_exhaustion_certificate"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "claim_id",
                "kind",
                "support_state_id",
                "certification_state_id"
              ]
            }
          }
        ]
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
