          },
          "semantic_obligations_hold": {
            "type": "boolean"
          },
          "extension_record_id": {
            "type": "string"
          },
          "extension_namespace": {
            "type": "string"
          },
          "base_theorem_ceiling": {
            "type": "integer",
            "minimum": 0
          },
          "extension_theorem_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^T[0-9]+$"
            },
            "uniqueItems": true
          },
          "observed_claim_kinds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
