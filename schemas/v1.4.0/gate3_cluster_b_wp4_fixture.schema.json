{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "binding": {
      "type": "object"
    },
    "classification": {
      "enum": [
        "positive",
        "negative",
        "boundary"
      ]
    },
    "expected": {
      "type": "object"
    },
    "fixture_id": {
      "minLength": 1,
      "type": "string"
    },
    "proof_manifest_delta": {
      "type": "object"
    }
  },
  "required": [
    "fixture_id",
    "classification",
    "binding",
    "proof_manifest_delta",
    "expected"
  ],
  "type": "object"
}
