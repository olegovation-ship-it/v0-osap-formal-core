    "input": {"type": "object"},
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "diagnostic_codes", "derived"],
      "properties": {
        "status": {"enum": ["PASS", "DEFERRED", "REJECT"]},
        "diagnostic_codes": {
          "type": "array",
