{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gate 3 Cluster B WP0 Post-Merge Closeout Gates",
  "type": "object",
  "required": [
    "artifact_id",
    "version",
    "date",
    "gate_count",
    "gates",
    "decision",
    "release_authorized"
  ],
  "properties": {
    "artifact_id": {
      "const": "V0_OSAP_GATE3_CLUSTER_B_WP0_POST_MERGE_CLOSEOUT_GATES"
    },
    "version": {
      "const": "0.1"
    },
    "date": {
      "type": "string"
    },
    "gate_count": {
      "const": 12
    },
    "gates": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^PM[0-9]{2}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "const": "PASS"
          }
        },
        "additionalProperties": false
      }
    },
    "decision": {
      "const": "POST_MERGE_CLOSEOUT_READY_FOR_PR"
    },
    "release_authorized": {
      "const": false
    }
  },
  "additionalProperties": false
}
